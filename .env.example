# ===========================================
# 건설인 웹 환경 변수 설정
# ===========================================

# --- Supabase 설정 ---
# Supabase 프로젝트 URL (대시보드 > Settings > API에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 익명 키 (클라이언트 사이드에서 사용, 공개 가능)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Supabase 서비스 역할 키 (서버 사이드 전용, 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# --- AI 기능 설정 (매칭, 자동지원, 챗봇, 분석) ---
# OpenRouter API 키 (https://openrouter.ai에서 발급)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# --- 배포 설정 ---
# 앱 공개 URL (Vercel 배포 시 도메인 설정)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# --- 크론 작업 보안 ---
# 자동지원 크론 작업 인증 시크릿 (임의 문자열 생성 권장)
CRON_SECRET=your-random-cron-secret-string

# --- 결제 설정 (선택사항) ---
# 토스페이먼츠 시크릿 키 (결제 기능 사용 시에만 필요)
# TOSS_SECRET_KEY=test_sk_your-toss-secret-key
